NEXT_PUBLIC_SUPABASE_URL=https://lezqahtkehsslvjaszfn.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_OR_PUBLISHABLE_KEY

# Used to sign session cookies (generate a long random string)
AUTH_SECRET=replace_with_long_random_secret

# The public site URL (used server-side to call internal webhook routes)
# Local example: http://localhost:3000
NEXT_PUBLIC_SITE_URL=

# Internal secret used when calling /api/webhooks/* routes (recommended)
INTERNAL_WEBHOOK_SECRET=

# Encryption key for storing ID numbers securely (recommended 32 random bytes base64)
NATIONAL_ID_ENCRYPTION_KEY=

# Supabase admin key (server-side only) for admin user creation
SUPABASE_SERVICE_ROLE_KEY=

# Outgoing webhooks (set the full URL to your automation endpoint)
# If a URL is empty/missing, that integration is skipped.
WHATSAPP_WEBHOOK_URL=
WHATSAPP_WEBHOOK_SECRET=

GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_WEBHOOK_SECRET=

# Optional helper envs for external WhatsApp provider (used outside this app,
# for example in Make/Zapier or your own bridge service).
WHATSAPP_TARGET_PHONE=+972532321101
WHATSAPP_PROVIDER=twilio|360dialog|other
WHATSAPP_API_KEY=YOUR_PROVIDER_API_KEY

# Optional: maps provider key if you embed a live GPS map widget
MAPS_API_KEY=

